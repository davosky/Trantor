<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <span class='text-info'><%= fa_icon('wrench') %></span>&nbsp;&nbsp;MOTIVI MISSIONE
      <span class='pull-right'>
        <%= link_to fa_icon('pencil'), new_mission_reason_path, class: 'btn btn-default btn-sm', id: 'text-success' %>
      </span>
    </h4>
    <hr>
    <table class='table table-striped table-hover'>
      <thead>
        <tr>
          <th>MOTIVO MISSIONE:</th>
          <th colspan='1'></th>
          <th colspan='2'></th>
        </tr>
      </thead>
      <tbody>
        <% @mission_reasons.each do |mission_reason| %>
          <tr>
            <td>
              <%= link_to mission_reason.name, mission_reason, id: 'text-info' %>
            </td>
            <td>
              <small>
                <%= mission_reason.position %>
              </small>
            </td>
            <td>
              <%= link_to fa_icon('pencil'), edit_mission_reason_path(mission_reason), id: 'text-warning' %>
            </td>
            <td>
              <%= link_to fa_icon('trash'), mission_reason, method: :delete, data: { confirm: 'Sei sicuro/a di voler eliminare il Motivo Missione corrente?' }, id: 'text-danger' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <br>
    <%= will_paginate @mission_reasons, renderer: BootstrapPagination::Rails %>
  </div>
</div>
