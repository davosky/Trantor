<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <span class='text-info'><%= fa_icon('map-marker') %></span>&nbsp;&nbsp;LUOGO MISSIONE
      <span class='pull-right'>
        <%= link_to fa_icon('arrow-left'), mission_places_path, class: 'btn btn-default btn-sm' %>
        &nbsp;
        <%= link_to fa_icon('pencil'), edit_mission_place_path(@mission_place), class: 'btn btn-default btn-sm', id: 'text-warning' %>
      </span>
    </h4>
    <hr>
    <dl class='dl-horizontal'>
      <dt>LUOGO MISSIONE:</dt>
      <dd>
        <%= @mission_place.name %>
      </dd>
      <dt>
        <h6>
          <small>
            Posizione
          </small>
        </h6>
      </dt>
      <dd>
        <h6>
          <small>
            <%= @mission_place.position %>
          </small>
        </h6>
      </dd>
    </dl>
  </div>
</div>
