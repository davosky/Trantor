<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <span class='text-info'><%= fa_icon('car') %></span>&nbsp;&nbsp;MEZZO
      <span class='pull-right'>
        <%= link_to fa_icon('arrow-left'), veichles_path, class: 'btn btn-default btn-sm' %>
        &nbsp;
        <% if @veichle.name == '-' %>
        <% else %>
          <%= link_to fa_icon('pencil'), edit_veichle_path(@veichle), class: 'btn btn-default btn-sm', id: 'text-warning' %>
        <% end %>
      </span>
    </h4>
    <hr>
    <dl class='dl-horizontal'>
      <dt>MODELLO:</dt>
      <dd>
        <%= @veichle.name %>
      </dd>
      <dt>PRODUTTORE:</dt>
      <dd>
        <%= @veichle.producer %>
      </dd>
      <dt>TARGA:</dt>
      <dd>
        <%= @veichle.licenceplate %>
      </dd>
      <dt>
        <h6>
          <small>
            POSIZIONE:
          </small>
        </h6>
      </dt>
      <dd>
        <h6>
          <small>
            <%= @veichle.position %>
          </small>
        </h6>
      </dd>
    </dl>
  </div>
</div>
