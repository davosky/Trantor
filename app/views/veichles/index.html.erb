<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <%= fa_icon('car') %>&nbsp;&nbsp;MEZZI
      <span class='pull-right'>
        <%= link_to fa_icon('pencil'), new_veichle_path, class: 'btn btn-default btn-sm', id: 'text-success' %>
      </span>
    </h4>
    <hr>
    <table class='table table-striped table-hover'>
      <thead>
        <tr>
          <th>MODELLO:</th>
          <th>PRODUTTORE:</th>
          <th>TARGA:</th>
          <th colspan='1'></th>
          <th colspan='2'></th>
        </tr>
      </thead>
      <tbody>
        <% @veichles.each do |veichle| %>
          <tr>
            <td><%= link_to veichle.name, veichle, id: 'text-info' %></td>
            <td><%= veichle.producer %></td>
            <td><%= veichle.licenceplate %></td>
            <td>
                <small>
                  <%= veichle.position %>
                </small>
            </td>
            <% if veichle.name == '-' %>
              <td></td>
              <td></td>
            <%else %>
              <td><%= link_to fa_icon('pencil'), edit_veichle_path(veichle), id: 'text-warning' %></td>
              <td><%= link_to fa_icon('trash'), veichle, method: :delete, data: { confirm: 'Sei sicuro/a di voler eliminare il Mezzo corrente?' }, id: 'text-danger' %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>