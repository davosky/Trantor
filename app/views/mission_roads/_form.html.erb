<div class='row'>
  <div class='col col-md-4'>
    <%= form_with(model: mission_road, local: true) do |form| %>
    <% if mission_road.errors.any? %>
    <div id='error_explanation'>
      <h2>
        <%= pluralize(mission_road.errors.count, 'error') %> non posso salvare il record corrente:</h2>
      <ul>
        <% mission_road.errors.full_messages.each do |message| %>
        <li>
          <%= message %>
        </li>
        <% end %>
      </ul>
    </div>
    <% end %>
    <div class='field'>
      <%= form.label 'PERCORSO MISSIONE:' %>
      <%= form.text_field :name, class: 'form-control' %>
    </div>
    <div class='field'>
      <%= form.label 'KM PERCORSO:' %>
      <%= form.text_field :km, class: 'form-control' %>
    </div>
    <div class='field'>
      <%= form.label 'COSTO AUTOSTRADA:' %>
      <%= form.text_field :highway_cost, class: 'form-control' %>
    </div>
    <div class='field'>
      <%= form.label 'POSIZIONE' %>
      <%= form.number_field :position, class: 'form-control' %>
    </div>
    <br>
    <div class='form-group'>
      <%= button_tag(type: 'submit', class: 'btn btn-success btn-sm') do %>
      <%= fa_icon('save') %>&nbsp;Salva
      <% end %>
    </div>
    <% end %>
  </div>
</div>
