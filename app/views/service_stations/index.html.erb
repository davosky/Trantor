<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <i class="fas fa-gas-pump"></i>&nbsp;&nbsp;GESTORI
      <span class='pull-right'>
        <%= link_to fa_icon('pencil'), new_service_station_path, class: 'btn btn-default btn-sm', id: 'text-success' %>
      </span>
    </h4>
    <hr>
    <table class='table table-striped table-hover'>
      <thead>
        <tr>
          <th>POSIZIONE:</th>
          <th>GESTORE:</th>
          <th>LUOGO:</th>
          <th>PI:</th>
          <th colspan='1'></th>
          <th colspan='2'></th>
        </tr>
      </thead>
      <tbody>
        <% @service_stations.each do |service_station| %>
        <tr>
          <td>
            <%= service_station.position %>
          </td>
          <td>
            <%= link_to service_station.name, service_station, id: 'text-info' %>
          </td>
          <td>
            <%= service_station.city %>
          </td>
          <td>
            <%= service_station.vat_number %>
          </td>
          <%else %>
          <td>
            <%= link_to fa_icon('pencil'), edit_service_station_path(service_station), id: 'text-warning' %>
          </td>
          <td>
            <%= link_to fa_icon('trash'), service_station, method: :delete, data: { confirm: 'Sei sicuro/a di voler eliminare il Gestore corrente?' }, id: 'text-danger' %>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>