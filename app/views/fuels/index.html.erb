<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <%= inline_svg('fuel_list_icon.svg', size: '50px * 30px', preserve_aspect_ratio: 'xMaxYMax meet') %>
      &nbsp;&nbsp;
      ELENCO SCHEDE CARBURANTE
    </h4>
    <hr>
    <table class='table table-striped table-hover'>
      <thead>
        <tr>
          <th>N°</th>
          <th>Data</th>
          <th>Luogo</th>
          <th>Stazione Servizio</th>
          <th colspan='2'></th>
        </tr>
      </thead>
      <tbody>
        <% @fuels.each do |fuel| %>
        <tr>
          <td>
            <strong>
              <%= link_to fuel.name, fuel, id: 'text-info', title: 'DETTAGLIO del record corrente', 'data-toggle' => 'tooltip', 'data-placement' => 'top' %>
            </strong>
          </td>
          <td>
            <%= fuel.date.strftime('%d/%m/%Y') %>
          </td>
          <td>
            <%= fuel.place %>
          </td>
          <td>
            <%= fuel.service_station.name %>
          </td>
          <td>
            <%= link_to fa_icon('pencil'), edit_fuel_path(fuel), id: 'text-warning', id: 'text-warning', title: 'MODIFICA il record corrente', 'data-toggle' => 'tooltip', 'data-placement' => 'top' %>
          </td>
          <td>
            <%= link_to fa_icon('trash'), fuel, method: :delete, data: { confirm: 'Sei sicuro/a di voler eliminare la scheda corrente?' }, id: 'text-danger', title: 'ELIMINA il record corrente', 'data-toggle' => 'tooltip', 'data-placement' => 'top' %>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
    <br>
    <%= will_paginate @fuels, renderer: BootstrapPagination::Rails %>
  </div>
</div>
