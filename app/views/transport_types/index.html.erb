<div class='panel panel-default'>
  <div class='panel-body'>
    <h4>
      <%= fa_icon('truck') %>&nbsp;&nbsp;TIPOLOGIE MEZZO
      <span class='pull-right'>
        <%= link_to fa_icon('pencil'), new_transport_type_path, class: 'btn btn-default btn-sm', id: 'text-success' %>
      </span>
    </h4>
    <hr>
    <table class='table table-striped table-hover'>
      <thead>
        <tr>
          <th>TIPOLOGIA MEZZO</th>
          <th colspan='1'></th>
          <th colspan='2'></th>
        </tr>
      </thead>
      <tbody>
        <% @transport_types.each do |transport_type| %>
          <tr>
            <td><%= link_to transport_type.name, transport_type, id: 'text-info' %></td>
            <td>
              <small>
                <%= transport_type.position %>
              </small>
            </td>
            <td><%= link_to fa_icon('pencil'), edit_transport_type_path(transport_type), id: 'text-warning' %></td>
            <td><%= link_to fa_icon('trash'), transport_type, method: :delete, data: { confirm: 'Sei sicuro/a di voler eliminare la Tipologia Mezzo corrente?' }, id: 'text-danger' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>